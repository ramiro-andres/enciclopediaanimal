{
  "ci": {
    "collect": {
      "staticDistDir": "./_site",
      "url": ["http://localhost/index.html"],
      "numberOfRuns": 1,
      "settings": {
        "onlyCategories": ["accessibility", "performance", "best-practices", "seo"],
        "skipAudits": ["uses-http2"]
      }
    },
    "assert": {
      "assertions": {
        "categories:accessibility": ["error", { "minScore": 0.9 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
